{
  "expo": {
    "name": "FastInsure Technologies",
    "slug": "fastinsure-technologies",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fastsaf",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anonymous.superfast",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.anonymous.superfast",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "OKXS",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/okxs-regular.ttf",
                    "weight": 400
                  }
                ]
              },
              {
                "fontFamily": "OKXS-Medium",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/okxs-medium.ttf",
                    "weight": 500
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/okxs-regular.ttf",
              "./assets/fonts/okxs-medium.ttf"
            ]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
